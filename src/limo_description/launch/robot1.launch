<launch>
    <param name="robot_description" textfile="$(find limo_description)/urdf/urdf/robot1.urdf" />
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find limo_description)/rviz/robot.rviz" />

    <!--机器人状态发布节点 -->
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
    <!--机器人关节状态发布节点（已注释，防止与 GUI 冲突） -->
    <!-- <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher"/> -->
    <!--添加控制关节运动的节点来测试关节是否合理-->
    <node pkg="joint_state_publisher_gui" name="joint_state_publisher_gui" type="joint_state_publisher_gui" />

</launch>           