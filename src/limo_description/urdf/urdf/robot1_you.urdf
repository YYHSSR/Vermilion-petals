<!-- <机器人底盘加摄像头> -->
<robot name="robot1">
    <!--添加极小尺寸的link,再去关联初始link与base_link，关节高度刚好与base_link下沉一致-->
    <link name="base_footprint">
        <visual>
            <!-- 底盘.形状 -->
            <geometry>
                <box size="0.001 0.001 0.001"/>
            </geometry> 
        </visual>   
    </link>


    <link name="base_link">
        <visual>
            <!-- 底盘.形状 -->
            <geometry>
                <box size="0.4 0.2 0.1"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="base_link_color"> 
                  <color rgba="0 0 1 0.5"/>   
            </material>        
        </visual>   
    </link>

    <link name="camera_link">
        <visual>
            <!-- 摄像头.形状 -->
            <geometry>
                <box size="0.02 0.05 0.05"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <material name="camera_link_color"> 
                  <color rgba="1 0 0 1"/>   
            </material>        
        </visual>   
    </link>

    <!--下沉与初始link关联-->   
    <joint name="base_footprint_base_link" type="fixed">
        <!-- 1.被固定的link -->
        <parent link="base_footprint"/>
        <!-- 2.要运动的link -->
        <child link="base_link"/>
        <!-- 3.运动的坐标原点 -->
        <origin xyz="0 0 0.05" rpy="0 0 0"/>  
    </joint>    

    <!-- 摄像头与底盘的固定关系 -->
    <joint name="camera_link_base_link_joint" type="continuous">
        <!-- 1.被固定的link -->
        <parent link="base_link"/>
        <!-- 2.要运动的link -->
        <child link="camera_link"/>
        <!-- 3.运动的坐标原点 -->
        <origin xyz="0.1 0 0.05" rpy="0 0 0"/>  
        <!-- 绕哪个轴旋转 -->
        <axis xyz="0 0 1"/>
    </joint>

</robot>