<robot name="robot2">

    <!--添加下沉-->
    <link name="base_footprint">
        <visual>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
        </visual>
    </link>

    <!--添加底盘-->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.08"/>
            </geometry>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <material name="base_link_color">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <!--下沉与底盘-->
    <joint name="base_footprint_to_base_link" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.055" rpy="0 0 0.0"/>
    </joint>

    <!--添加驱动轮-->
    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.035" length="0.015"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="left_wheel_color">
                <color rgba="0 1 0 1"/>
            </material>
        </visual>
    </link>

    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.035" length="0.015"/>
            </geometry>
             <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="right_wheel_color">
                <color rgba="0 1 0 1"/>
            </material>
        </visual>
    </link>

    <joint name="base_link_to_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0 0.1 -0.0225" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_link_to_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0 -0.1 -0.0225" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!--万向轮-->
    <link name="caster_front_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.0075"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="caster_front_wheel_color">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <link name="caster_back_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.0075"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="caster_back_wheel_color">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="base_link_to_caster_front_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="caster_front_wheel_link"/>
        <origin xyz="0.1 0 -0.0475" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_link_to_caster_back_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="caster_back_wheel_link"/>
        <origin xyz="-0.1 0 -0.0475" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

</robot>