<launch>
  <!-- YDLIDAR X2/X2L 雷达驱动节点 -->
  <node name="ydlidar_node" pkg="ydlidar_ros" type="ydlidar_node" output="screen" respawn="true">
    <!-- 硬件通信配置 -->
    <param name="port"              type="string" value="/dev/ydlidar" />
    <param name="baudrate"          type="int"    value="115200" />
    <param name="frame_id"          type="string" value="laser_link" />
    <param name="auto_reconnect"    type="bool"   value="true" />
    <param name="reversion"         type="bool"   value="true" />

    <!-- 扫描参数配置 -->
    <!-- angle_min/max: 扫描范围控制在 [-180, 180] 表示 360° 全向扫描 -->
    <param name="angle_min"         type="double" value="-180" />
    <param name="angle_max"         type="double" value="180" />
    <param name="range_min"         type="double" value="0.1" />
    <param name="range_max"         type="double" value="12.0" />
    <!-- ignore_array: 精准屏蔽正后方被小车立柱/显示屏遮挡的角度范围（145° - 215°） -->
    <param name="ignore_array"      type="string" value="145,215" />

    <!-- 采样及工作频率配置 -->
    <param name="frequency"         type="double" value="8" />
    <param name="samp_rate"         type="int"    value="3" />
    <param name="resolution_fixed"  type="bool"   value="true" />
    <param name="isSingleChannel"   type="bool"   value="true" />
  </node>
</launch>
